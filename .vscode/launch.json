{
    "version": "0.2.0",
    "configurations": [
        

        {
            "name": "Debug CyberForce",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cyberforce.exe",
            "args": ["-t", "http://localhost:8080", "-U", "test", "-P", "test", "-v", "3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\mingw64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build CyberForce"
        }
    ]
}